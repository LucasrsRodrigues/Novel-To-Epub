# Novel-to-EPUB · backend env vars
#
# Copie pra `.env` (na mesma pasta) e ajuste. Tudo aqui é OPCIONAL — o app
# roda sem nada disto. Tradução e envio pro Kindle requerem as chaves
# correspondentes; o resto vai por padrão.
#
# Env vars têm prioridade sobre as chaves salvas via UI no SQLite.

# ─── HTTP / scraper ──────────────────────────────────────────────────────
NOVEL_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING
NOVEL_LOG_JSON=false            # true em servidor (logs estruturados)
NOVEL_MIN_DELAY=1.0             # delay mínimo entre requests (s)
NOVEL_MAX_DELAY=3.0             # delay máximo entre requests (s)
NOVEL_REQUEST_TIMEOUT=30        # timeout por request (s)
NOVEL_MAX_RETRIES=3             # tentativas em falhas transitórias

# ─── Onde gravar dados (cache.sqlite3 + epubs/) ──────────────────────────
# Default: ./data (dev). Em produção (Electron empacotado) é sobrescrito
# pelo main process com app.getPath('userData').
# NOVEL_DATA_DIR=/caminho/absoluto

# ─── Tradução IA (cascade) ────────────────────────────────────────────────
# Pelo menos UMA chave é necessária pra usar a tradução. A ordem do cascade
# é configurável em Configurações > Tradução na UI (default abaixo).
# Cascade default: Groq → OpenRouter → Cerebras → Gemini

GEMINI_API_KEY=                 # https://aistudio.google.com/apikey  (também usado pra capa IA)
GROQ_API_KEY=                   # https://console.groq.com/keys       (free tier generoso)
OPENROUTER_API_KEY=             # https://openrouter.ai/keys
CEREBRAS_API_KEY=               # https://cloud.cerebras.ai/platform  (free tier)
